# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.svg text eol=lf

# Declare binary files
*.png binary
*.ico binary
*.icns binary
*.node binary
*.wasm binary
