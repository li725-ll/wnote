{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "@wnote/shared": ["../shared/src/index.ts"],
      "@wnote/shared/*": ["../shared/src/*.ts"],
      "@wnote/md-parser": ["../md-parser/src/index.ts"],
      "@wnote/md-parser/*": ["../md-parser/src/*.ts"],
      "@wnote/logger/main": ["../logger/src/main.ts"]
    }
  },
  "include": ["src"]
}
