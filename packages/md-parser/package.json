{
  "name": "@wnote/md-parser",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./pkg/md_parser.js"
    },
    "./types": {
      "types": "./src/types.ts"
    },
    "./node": {
      "types": "./src/index.ts",
      "require": "./pkg-node/md_parser.js"
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "build:web": "wasm-pack build --release --target bundler --out-dir pkg --out-name md_parser",
    "build:node": "wasm-pack build --release --target nodejs --out-dir pkg-node --out-name md_parser",
    "test": "cargo test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf pkg pkg-node target"
  },
  "files": [
    "pkg",
    "pkg-node",
    "src"
  ],
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
